<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
        Suppression file for OWASP Dependency-Check (Node.js/npm)
        Add suppressions for false positives and reviewed/accepted vulnerabilities.
        See: https://jeremylong.github.io/DependencyCheck/general/suppression.html
    -->

    <!-- Angular 17 - XSS/XSRF. Upgrade to Angular 18+ when feasible. Suppress until upgrade planned. -->
    <suppress until="2026-06-01Z">
        <notes><![CDATA[
        Angular 17.3.12 has known XSS/XSRF vulnerabilities. Fix requires upgrade to Angular 18.2.15+ or 19+/21.
        Planning Angular 18 upgrade. See: GHSA-58c5-g7wp-6w37, GHSA-v4hv-rgfq-gp49, GHSA-jrmj-c5cx-3cw6
        ]]></notes>
        <packageUrl regex="true">^pkg:npm/%40angular%2Fcommon@.*$</packageUrl>
        <vulnerabilityName>GHSA-58c5-g7wp-6w37</vulnerabilityName>
    </suppress>
    <suppress until="2026-06-01Z">
        <notes><![CDATA[Angular compiler - XSS. Upgrade to Angular 18+ required.]]></notes>
        <packageUrl regex="true">^pkg:npm/%40angular%2Fcompiler@.*$</packageUrl>
        <vulnerabilityName>GHSA-v4hv-rgfq-gp49</vulnerabilityName>
        <vulnerabilityName>GHSA-jrmj-c5cx-3cw6</vulnerabilityName>
    </suppress>
    <suppress until="2026-06-01Z">
        <notes><![CDATA[Angular core - XSS. Upgrade to Angular 18+ required.]]></notes>
        <packageUrl regex="true">^pkg:npm/%40angular%2Fcore@.*$</packageUrl>
        <vulnerabilityName>GHSA-jrmj-c5cx-3cw6</vulnerabilityName>
    </suppress>

    <!-- minimatch - ReDoS (CVE-2026-26996). Transitive from @typescript-eslint, glob, ignore-walk, etc. -->
    <!-- Fix: 9.0.6+ (9.x), 10.2.1+ (10.x), 3.1.3 (3.x). Add overrides when Angular/tooling upgraded. -->
    <suppress until="2026-06-01Z">
        <notes><![CDATA[
        minimatch ReDoS - CVE-2026-26996, GHSA-23c5-xmqv-rm74, GHSA-7r86-cg39-jmmj.
        Transitive deps. Dev/build-time only. Re-evaluate on Angular 18+ upgrade.
        ]]></notes>
        <packageUrl regex="true">^pkg:npm/minimatch@.*$</packageUrl>
        <vulnerabilityName>GHSA-3ppc-4f35-3m26</vulnerabilityName>
        <vulnerabilityName>CVE-2026-26996</vulnerabilityName>
        <vulnerabilityName>GHSA-23c5-xmqv-rm74</vulnerabilityName>
        <vulnerabilityName>GHSA-7r86-cg39-jmmj</vulnerabilityName>
    </suppress>

    <!-- rollup - Path traversal/RCE (CVE-2026-27606). From @angular-devkit/build-angular. -->
    <!-- Fix: 4.59.0+. Re-evaluate on Angular upgrade. -->
    <suppress until="2026-06-01Z">
        <notes><![CDATA[
        rollup path traversal - CVE-2026-27606, GHSA-mw96-cpmx-2vgc.
        Build-time only, CI runs in isolated runner. Re-evaluate on Angular 18+ upgrade.
        ]]></notes>
        <packageUrl regex="true">^pkg:npm/rollup@.*$</packageUrl>
        <vulnerabilityName>CVE-2026-27606</vulnerabilityName>
        <vulnerabilityName>GHSA-mw96-cpmx-2vgc</vulnerabilityName>
    </suppress>

    <!-- qs - CVE-2026-2391 (CVSS 6.3). Transitive, dev/build-time. -->
    <suppress until="2026-06-01Z">
        <notes><![CDATA[
        qs CVE-2026-2391. Transitive from express/connect. Dev-time only.
        ]]></notes>
        <packageUrl regex="true">^pkg:npm/qs@.*$</packageUrl>
        <vulnerabilityName>CVE-2026-2391</vulnerabilityName>
    </suppress>

    <!-- serialize-javascript - GHSA-5c6j-r48x-rmvq. Transitive from webpack/html-webpack-plugin. -->
    <!-- Dev/build-time only. Re-evaluate on Angular upgrade. -->
    <suppress until="2026-06-01Z">
        <notes><![CDATA[
        serialize-javascript GHSA-5c6j-r48x-rmvq. Transitive from webpack tooling. Build-time only.
        ]]></notes>
        <packageUrl regex="true">^pkg:npm/serialize-javascript@.*$</packageUrl>
        <vulnerabilityName>GHSA-5c6j-r48x-rmvq</vulnerabilityName>
    </suppress>

    <!-- tar - Path traversal/symlink. Override to ^7.5.8 in package.json. Run npm install to apply. -->
    <suppress until="2026-06-01Z">
        <notes><![CDATA[
        tar path traversal/symlink vulnerabilities. package.json has override to ^7.5.8.
        Ensure npm install has been run to apply override.
        ]]></notes>
        <packageUrl regex="true">^pkg:npm/tar@.*$</packageUrl>
        <vulnerabilityName>GHSA-8qq5-rm4j-mr97</vulnerabilityName>
        <vulnerabilityName>GHSA-r6q2-hw4h-h46w</vulnerabilityName>
        <vulnerabilityName>GHSA-34x7-hfp2-rc4v</vulnerabilityName>
        <vulnerabilityName>GHSA-83g3-92jg-28cx</vulnerabilityName>
    </suppress>
</suppressions>
